{
  "name": "mieru-toroku",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "postinstall": "node scripts/patch-zustand.js",
    "build:web": "node scripts/patch-zustand.js && expo export --platform web && node scripts/patch-bundle.js",
    "serve:web": "npm run build:web && npx serve dist --listen 8082 --single",
    "ts-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.2",
    "babel-preset-expo": "~55.0.8",
    "date-fns": "^4.1.0",
    "expo": "~55.0.5",
    "expo-router": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.2.2",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
